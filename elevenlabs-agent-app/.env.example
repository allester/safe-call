# Get your Agent ID from https://elevenlabs.io/app/conversational-ai
# Create an agent and copy its ID. Use a public agent or configure auth (signed URL / token).
VITE_ELEVENLABS_AGENT_ID=your_agent_id_here

# Optional: WebSpatial visionOS — for run:avp (use the URL where dev:avp is serving, e.g. http://localhost:5173/webspatial/avp/)
# XR_DEV_SERVER=http://localhost:5173/webspatial/avp/

# Optional: For build:avp:ipa (signed visionOS app)
# XR_BUNDLE_ID=com.yourteam.elevenlabs-agent
# XR_TEAM_ID=YOUR_APPLE_TEAM_ID
